{
  "name": "project-dash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "opennextjs-cloudflare build && wrangler deploy && wrangler deploy --config workers/wrangler.toml",
    "deploy:app": "opennextjs-cloudflare build && wrangler deploy",
    "deploy:workers": "wrangler deploy --config workers/wrangler.toml",
    "db:migrate:local": "wrangler d1 execute project-dash-db --local --file=migrations/0001_initial.sql",
    "db:migrate:prod": "wrangler d1 execute project-dash-db --remote --file=migrations/0001_initial.sql",
    "cf:dev": "wrangler dev",
    "workers:dev": "wrangler dev --config workers/wrangler.toml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "aws4fetch": "^1.0.20",
    "next": "16.2.2",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
